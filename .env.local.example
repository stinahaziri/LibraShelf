# MongoDB Atlas connection string
# Merret nga: https://cloud.mongodb.com -> Database -> Connect -> Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/librashelf

# NextAuth
# Gjenero me: openssl rand -base64 32 (ose https://generate-secret.vercel.app/32)
NEXTAUTH_SECRET=vendos-nje-string-te-rastesishem-ketu
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
